{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "rn-debugger": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "react-native-ai-debugger"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    }
  }
}
